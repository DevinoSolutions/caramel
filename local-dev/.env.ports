# Caramel local port defaults (can be overridden per developer)
PORT=58000
PG_PORT=58005
REDIS_PORT=58006
# Optional future expansions
SOCKET_PORT=58003
WORKER_PORT=58002
TYPESENSE_PORT=58007

# Database URL for local development and E2E tests
DATABASE_URL="postgresql://user:password@localhost:58005/caramel?schema=public"
